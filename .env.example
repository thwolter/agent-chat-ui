# Optional default assistant shown in the login form.
NEXT_PUBLIC_ASSISTANT_ID=agent
# Optional public API proxy URL (default: /api)
NEXT_PUBLIC_API_PROXY_URL=/api

# Optional fallback backend URL when no authenticated session cookie exists.
LANGGRAPH_API_URL=http://localhost:8123
# Optional fallback token for service mode (server-side only).
LANGGRAPH_BEARER_TOKEN=
